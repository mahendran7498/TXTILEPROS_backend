{
  "compilerOptions": {
    "checkJs": false,
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2020"
  },
  "include": [
    "api/**/*.js",
    "middleware/**/*.js",
    "models/**/*.js",
    "routes/**/*.js",
    "utils/**/*.js"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "coverage"
  ]
}
